# ── SERVER ──────────────────────────────────────────────────────────────────────
# Railway sets PORT automatically in production.
PORT=8000
MCP_SERVER_NAME=cafe-mcp

# ── QUICKBOOKS ONLINE ────────────────────────────────────────────────────────────
# QB_CLIENT_ID + QB_CLIENT_SECRET
#   Where: developer.intuit.com → My Apps → Keys & Credentials
#   Create an app, select QuickBooks Online scope
QB_CLIENT_ID=
QB_CLIENT_SECRET=

# QB_REFRESH_TOKEN
#   Where: Run `python scripts/get_qb_token.py` once after setting CLIENT_ID/SECRET
QB_REFRESH_TOKEN=

# QB_REALM_ID
#   Your QuickBooks Company ID — visible in the URL when logged into QBO:
#   app.qbo.intuit.com/app/homepage?... the number after /c/ or in the URL params
QB_REALM_ID=

QB_ENVIRONMENT=production

# ── TOAST POS (identical to shibam-marketing-mcp — same values) ──────────────────
# These must match exactly what you set in the marketing server.
# If running both servers on the same host, one .env file can serve both.
TOAST_API_PENDING=true
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=
TOAST_RESTAURANT_GUID=
TOAST_ENVIRONMENT=production

# ── GMAIL + GOOGLE APIS ──────────────────────────────────────────────────────────
# This must be the Gmail account that receives vendor invoices: yemenicoffeeco@gmail.com
# GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET
#   Where: console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client
#   Enable: Gmail API and Google Sheets API in the Library tab
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GOOGLE_REFRESH_TOKEN
#   Where: Run `python scripts/get_google_token.py` — sign in as yemenicoffeeco@gmail.com
#   Covers both Gmail and Google Sheets with one token
GOOGLE_REFRESH_TOKEN=

# ── GOOGLE SHEETS ────────────────────────────────────────────────────────────────
# Get the Sheet ID from the URL: docs.google.com/spreadsheets/d/{SHEET_ID}/edit
GOOGLE_SHEETS_INVENTORY_ID=
GOOGLE_SHEETS_LEDGER_ID=

# ── OPENAI API (for PDF invoice parsing) ─────────────────────────────────────────
# Where: platform.openai.com → API keys → Create new secret key
# Note: Separate from ChatGPT Pro subscription — requires API credits (~$0.002/invoice)
OPENAI_API_KEY=

# ── WHENIWORK ────────────────────────────────────────────────────────────────────
# WHENIWORK_API_KEY
#   Where: WhenIWork web app → Account Settings → API → Generate API Key
WHENIWORK_API_KEY=

# WHENIWORK_ACCOUNT_ID
#   Where: Visible in WhenIWork URL or Account Settings
WHENIWORK_ACCOUNT_ID=

# ── VENDOR EMAIL DOMAINS ─────────────────────────────────────────────────────────
# Set the sender email domain for each vendor's invoice emails.
# The Gmail parser searches for emails FROM these domains.
# To add a new vendor: add a new VENDOR_* variable here — no code changes needed.
VENDOR_RESTAURANT_DEPOT=restaurantdepot.com
VENDOR_INSTACART=instacart.com
VENDOR_WEBSTAURANT=webstaurantstore.com
VENDOR_BARISTA_UNDERGROUND=baristaunderground.com
VENDOR_FRANCHISOR=
VENDOR_DESSERT_VENDOR=
# Template for new vendors: VENDOR_<UPPERCASE_NAME>=<email_domain_or_address>

# ── GOOGLE ADS ──────────────────────────────────────────────────────────────────
# GOOGLE_ADS_DEVELOPER_TOKEN
#   Where: Google Ads UI → Tools & Settings → API Center
#   Note: Apply for Basic access (not Test) to query live data.
GOOGLE_ADS_DEVELOPER_TOKEN=

# GOOGLE_ADS_CLIENT_ID + GOOGLE_ADS_CLIENT_SECRET
#   Where: console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client
#   App type: Desktop application
#   Enable: Google Ads API in the Library tab
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# GOOGLE_ADS_REFRESH_TOKEN
#   Where: Run `python scripts/get_refresh_token.py` once after setting CLIENT_ID and SECRET above.
#   Required scope: https://www.googleapis.com/auth/adwords
GOOGLE_ADS_REFRESH_TOKEN=

# GOOGLE_ADS_CUSTOMER_ID
#   Your Google Ads account ID without dashes (Shibam's is 3307041753).
GOOGLE_ADS_CUSTOMER_ID=3307041753

# GOOGLE_ADS_LOGIN_CUSTOMER_ID
#   Only needed if your account is under a Manager (MCC) account.
#   Leave blank if you log into ads.google.com directly with no manager layer.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ── META ADS ────────────────────────────────────────────────────────────────────
# META_ACCESS_TOKEN
#   Best option (never expires): System User Token
#     business.facebook.com → Business Settings → System Users
#     → Create System User (Admin) → Generate Token → select ad account act_817875271884127
#     → select permissions: ads_read, ads_management, business_management
#   Alternative (expires every 60 days): Long-lived User Token
#     developers.facebook.com → Tools → Graph API Explorer → Generate → Extend Token
META_ACCESS_TOKEN=

# META_AD_ACCOUNT_ID — always include the act_ prefix
META_AD_ACCOUNT_ID=act_817875271884127

# META_APP_ID + META_APP_SECRET
#   Where: developers.facebook.com → Your App → Settings → Basic
META_APP_ID=
META_APP_SECRET=

# ── GOOGLE BUSINESS PROFILE ─────────────────────────────────────────────────────
# Enable "Business Profile Performance API" at:
#   console.cloud.google.com → Library → search "Business Profile"
# GBP_ACCOUNT_ID + GBP_LOCATION_ID
#   Where: Run `python scripts/get_refresh_token.py` with GBP scope, then call
#          GET https://mybusinessaccountmanagement.googleapis.com/v1/accounts
#          to find your account ID and location ID.
GBP_ACCOUNT_ID=
GBP_LOCATION_ID=

# GOOGLE_PLACES_API_KEY
#   Where: console.cloud.google.com → APIs & Services → Credentials → Create API Key
#   Restrict it to "Places API" only under API restrictions for security.
#   Enable: Places API in the Library tab
GOOGLE_PLACES_API_KEY=

# ── INSTAGRAM ───────────────────────────────────────────────────────────────────
# INSTAGRAM_ACCESS_TOKEN
#   Best option: Same System User as Meta Ads above — grant instagram_basic
#     and instagram_manage_insights permissions when generating the token.
#   Alternative: developers.facebook.com → Graph API Explorer
#     → select your app → select your Instagram Business Account
#     → add permissions: instagram_basic, instagram_manage_insights
#     → Generate → then extend to a long-lived token
INSTAGRAM_ACCESS_TOKEN=

# INSTAGRAM_BUSINESS_ACCOUNT_ID
#   Where: Graph API Explorer → GET /{facebook-page-id}?fields=instagram_business_account
#   Or: business.facebook.com → Accounts → Instagram Accounts → click your account
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ── MCP SERVER AUTHENTICATION (required — server refuses to start without) ────
# Static bearer key(s), comma-separated. Callers must send
# "Authorization: Bearer <key>". Generate: python -c "import secrets; print('wes_' + secrets.token_urlsafe(32))"
MCP_API_KEYS=

# ── MULTI-TENANT MODE (optional — omit for single-tenant env-var mode) ────────
# Postgres tenant store. When set, API keys minted via scripts/tenant_admin.py
# resolve to per-tenant credentials/settings (encrypted at rest).
DATABASE_URL=
# Fernet master key(s) "id:key" CSV, first entry is primary.
# Generate: python scripts/tenant_admin.py gen-master-key --key-id v1
TENANT_MASTER_KEY=

# ── OAUTH BRIDGE (optional — for OAuth-only connector UIs, e.g. Claude.ai) ────
# Set to this server's own public HTTPS URL to enable an OAuth 2.1 bridge
# in front of the existing bearer-key auth. See docs/oauth.md.
OAUTH_PUBLIC_URL=
