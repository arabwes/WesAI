{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ParsedInvoice",
  "description": "Structured invoice data extracted by Claude from a PDF or image attachment",
  "type": "object",
  "properties": {
    "vendor_name": {
      "type": "string",
      "description": "Name of the vendor or supplier"
    },
    "order_date": {
      "type": "string",
      "description": "Date of the order or invoice in YYYY-MM-DD format, or empty string"
    },
    "order_number": {
      "type": "string",
      "description": "Order or invoice number, used for deduplication"
    },
    "line_items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "quantity": { "type": ["number", "null"] },
          "unit": { "type": "string" },
          "unit_cost": { "type": ["number", "null"] },
          "line_total": { "type": ["number", "null"] }
        }
      }
    },
    "subtotal": { "type": ["number", "null"] },
    "tax": { "type": ["number", "null"] },
    "shipping": { "type": ["number", "null"] },
    "invoice_total": { "type": ["number", "null"] },
    "notes": { "type": "string" }
  },
  "required": ["vendor_name", "order_number", "line_items", "invoice_total"]
}
