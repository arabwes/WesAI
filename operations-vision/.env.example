# Copy to .env - NEVER commit the real .env.
#
# Reolink RTSP URLs (use the low-res substream for AI processing):
#   Preview_01_sub  = substream, Preview_01_main = full resolution
CAMERA_ENTRANCE_RTSP_URL=rtsp://username:password@192.168.1.50/Preview_01_sub
CAMERA_SERVICE_RTSP_URL=rtsp://username:password@192.168.1.51/Preview_01_sub
CAMERA_SEATING_RTSP_URL=rtsp://username:password@192.168.1.52/Preview_01_sub

# Optional overrides
# OPSVISION_CONFIG_DIR=C:/path/to/config
# OPSVISION_DATA_DIR=C:/path/to/data
# OPSVISION_DATABASE_URL=sqlite:///C:/path/to/operations.db
